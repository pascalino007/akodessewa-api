# Database Configuration
DATABASE_URL="postgresql://akodessewa_user:your_secure_password@localhost:5432/akodessewa_db"

# Application Configuration
NODE_ENV=production
PORT=4000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# DigitalOcean Spaces Configuration (Required for uploads)
SPACES_ENDPOINT=https://sfo2.digitaloceanspaces.com
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_REGION=sfo2
SPACES_BUCKET=myikigai
SPACES_CDN_URL=https://myikigai.sfo2.cdn.digitaloceanspaces.com

# AWS S3 Configuration (Alternative)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=your-aws-region
AWS_S3_BUCKET=your-s3-bucket-name

# CORS Configuration
CORS_ORIGIN=https://api.aakodessewa.com,http://localhost:4000,http://168.231.101.119:4000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# API Documentation
API_PREFIX=api/v1
API_TITLE=Akodessewa API
API_DESCRIPTION=Akodessewa Auto Parts Platform API
API_VERSION=1.0
